{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
      "@@/*": ["./.dumi/tmp/*"],
      "@rc-component/dialog": ["./src/index.ts"]
    },
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "strictFunctionTypes": false,
    "strict": false,
    "noImplicitThis": false,
    "strictBindCallApply": false,
    "module": "ESNext"
  },
  "include": [
    "global.d.ts",
    ".fatherrc.ts",
    ".dumirc.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./docs/**/*.tsx",
    "./tests/**/*.tsx"
  ]
}
