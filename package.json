{
  "name": "@rc-component/dialog",
  "version": "1.9.0",
  "description": "dialog ui component for react",
  "keywords": [
    "react",
    "react-component",
    "react-dialog",
    "dialog",
    "ui"
  ],
  "homepage": "https://react-component.github.io/dialog",
  "bugs": {
    "url": "https://github.com/react-component/dialog/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/react-component/dialog.git"
  },
  "license": "MIT",
  "author": "yiminghe@gmail.com",
  "main": "./lib/index",
  "module": "./es/index",
  "files": [
    "lib",
    "es",
    "assets/*.css"
  ],
  "scripts": {
    "build": "npm run docs:build",
    "compile": "father build && lessc assets/index.less assets/index.css && lessc assets/bootstrap.less assets/bootstrap.css",
    "coverage": "rc-test --coverage",
    "deploy": "npm run docs:build:gh-pages && npm run docs:deploy",
    "docs:build": "dumi build",
    "docs:deploy": "gh-pages -d docs-dist",
    "lint": "eslint src/ --ext .ts,.tsx,.jsx,.js,.md",
    "lint:tsc": "tsc -p tsconfig.json --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run compile && rc-np",
    "prettier": "prettier --write --ignore-unknown .",
    "start": "dumi dev",
    "test": "rc-test",
    "tsc": "tsc --noEmit",
    "docs:build:gh-pages": "GH_PAGES=1 npm run docs:build"
  },
  "lint-staged": {
    "**/*.{js,jsx,tsx,ts,md,json}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@rc-component/motion": "^1.3.3",
    "@rc-component/portal": "^2.1.0",
    "@rc-component/util": "^1.9.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@rc-component/drawer": "^1.0.0",
    "@rc-component/father-plugin": "^2.2.0",
    "@rc-component/np": "^1.0.4",
    "@rc-component/select": "^1.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.7",
    "@types/jest": "^29.5.14",
    "@types/keyv": "3.1.4",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@umijs/fabric": "^4.0.1",
    "bootstrap": "^5.3.7",
    "dumi": "^2.4.35",
    "eslint": "^8.57.1",
    "father": "^4.6.23",
    "gh-pages": "^6.3.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "less": "^4.6.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.0",
    "rc-test": "^7.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.4.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
